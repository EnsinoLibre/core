# EnsinoLibre teacher platform — build-time configuration (Vite).
#
# Copy to `.env` and fill in YOUR OWN Supabase project to self-host:
#   cp .env.example .env
# Leaving these unset builds against the public EnsinoLibre demo project.
# See ../SELF-HOSTING.md for the full setup (create project, run migrations).

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase publishable (anon) key. Safe to ship in client code —
# row-level security does the gating. NOT the service_role key.
VITE_SUPABASE_ANON_KEY=
