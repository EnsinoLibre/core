# EnsinoLibre core — self-host config for docker-compose.
# Copy to `.env` (docker compose reads it automatically), then fill in your own
# Supabase project. Unset = the public EnsinoLibre demo project.
# See SELF-HOSTING.md. (For a non-Docker Vite build, use platform/.env instead.)

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Your Supabase publishable (anon) key — safe in client code; RLS does the
# gating. NOT the service_role key.
SUPABASE_KEY=
